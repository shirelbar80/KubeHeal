# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Kubernetes ---
# Namespace KubeHeal watches and is allowed to patch. NEVER kube-system.
KUBEHEAL_NAMESPACE=kubeheal-demo
# Path to kubeconfig; leave empty to use the default (~/.kube/config) or in-cluster config.
KUBECONFIG_PATH=

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=granite3.1-dense:2b

# --- Slack (Socket Mode) ---
# Bot User OAuth Token, starts with xoxb-
SLACK_BOT_TOKEN=
# App-Level Token (connections:write scope), starts with xapp-
SLACK_APP_TOKEN=
# Channel where alerts are posted, e.g. #all-kubeheal-dev (or its channel ID)
SLACK_CHANNEL=#all-kubeheal-dev

# --- Safety / behavior ---
# Always require a human click. Keep false. (Auto-approve is intentionally unsupported.)
AUTO_APPROVE=false
# Per-workload cooldown in seconds to prevent alert storms / patch loops.
COOLDOWN_SECONDS=300
# How often to re-ping Slack about a pending approval no one has acted on yet.
REMINDER_SECONDS=900
# Lines of pod logs to send to the LLM.
LOG_TAIL_LINES=50
# Seconds to watch a workload after patching before declaring success/failure.
VERIFY_TIMEOUT_SECONDS=120

# --- State ---
DB_PATH=kubeheal.sqlite

# --- Optional internal API ---
HEALTH_PORT=8000
